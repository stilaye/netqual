    subgraph INPUTS["Input Sources"]
        LOG_FILE["рџ“„ Text Logs\n(.log files)\nsysdiagnose-style"]
        PCAP_FILE["рџ“¦ Packet Captures\n(.pcap / .logdump)\ntcpdump / btsnoop"]
