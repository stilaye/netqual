{
  "info": {
    "name": "Apple Applied Networking — QE Validation",
    "_postman_id": "apple-networking-qe-2025",
    "description": "API-level tests validating network protocols used by Apple's Sharing features.\n\nCovers:\n- TLS/SSL certificate validation (AirDrop security)\n- HTTP/2 protocol support (URLSession default)\n- HTTPS enforcement (App Transport Security)\n- DNS resolution (Bonjour/mDNS foundation)\n- Apple Push Notification endpoints\n- iCloud service availability\n\nPrepared by Swapnil for Apple SQE Interview",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://www.apple.com"
    }
  ],
  "item": [
    {
      "name": "1. TLS & Certificate Validation",
      "description": "Tests that validate TLS behavior — the foundation of secure Sharing features",
      "item": [
        {
          "name": "1.1 Apple.com TLS 1.3 Connection",
          "request": {
            "method": "GET",
            "url": "https://www.apple.com",
            "description": "Verify TLS 1.3 connection to Apple — same protocol used for AirDrop file encryption"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response time under 3 seconds', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});",
                  "",
                  "pm.test('HTTPS connection successful', function () {",
                  "    pm.expect(pm.request.url.protocol).to.equal('https');",
                  "});",
                  "",
                  "pm.test('HSTS header present (prevents downgrade)', function () {",
                  "    pm.expect(pm.response.headers.has('Strict-Transport-Security')).to.be.true;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "1.2 HTTPS Redirect Enforced (ATS Check)",
          "request": {
            "method": "GET",
            "url": "http://apple.com",
            "description": "HTTP should redirect to HTTPS — App Transport Security requirement"
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Disable auto-redirect to capture the 301/302",
                  "pm.request.maxRedirects = 0;"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('HTTP redirects to HTTPS (ATS enforcement)', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([301, 302, 307, 308]);",
                  "});",
                  "",
                  "pm.test('Location header points to HTTPS', function () {",
                  "    var location = pm.response.headers.get('Location');",
                  "    if (location) {",
                  "        pm.expect(location).to.match(/^https/);",
                  "    }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "1.3 Security Headers Validation",
          "request": {
            "method": "GET",
            "url": "https://www.apple.com"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('HSTS header present', function () {",
                  "    pm.expect(pm.response.headers.has('Strict-Transport-Security')).to.be.true;",
                  "});",
                  "",
                  "pm.test('Content-Type header present', function () {",
                  "    pm.expect(pm.response.headers.has('Content-Type')).to.be.true;",
                  "});",
                  "",
                  "pm.test('Server header does not leak version info', function () {",
                  "    var server = pm.response.headers.get('Server');",
                  "    if (server) {",
                  "        pm.expect(server).to.not.match(/\\d+\\.\\d+/);",
                  "    }",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. Apple Services Availability",
      "description": "Verify Apple backend services that Sharing features depend on",
      "item": [
        {
          "name": "2.1 iCloud Services Reachable",
          "request": {
            "method": "GET",
            "url": "https://www.icloud.com",
            "description": "iCloud underpins Handoff state sync and Universal Clipboard"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('iCloud is reachable', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response time acceptable', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(5000);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "2.2 Apple Developer Services",
          "request": {
            "method": "GET",
            "url": "https://developer.apple.com",
            "description": "Developer services host API documentation for GroupActivities, NSUserActivity"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Developer portal reachable', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Uses HTTPS', function () {",
                  "    pm.expect(pm.request.url.protocol).to.equal('https');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "2.3 Apple Push Notification Gateway",
          "request": {
            "method": "GET",
            "url": "https://api.push.apple.com",
            "description": "APNs is used to wake devices for Handoff and SharePlay invitations"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// APNs gateway won't return 200 without auth, but should be reachable",
                  "pm.test('APNs gateway responds (even if 403/405)', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 400, 403, 404, 405]);",
                  "});",
                  "",
                  "pm.test('Connection established over TLS', function () {",
                  "    pm.expect(pm.request.url.protocol).to.equal('https');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "2.4 Apple Identity Service",
          "request": {
            "method": "GET",
            "url": "https://identity.apple.com",
            "description": "Identity service validates device certificates for AirDrop"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Identity service reachable', function () {",
                  "    // May redirect or return various codes — just verify connection works",
                  "    pm.expect(pm.response.code).to.be.below(500);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "3. HTTP/2 Protocol Validation",
      "description": "URLSession uses HTTP/2 by default — SharePlay coordination depends on it",
      "item": [
        {
          "name": "3.1 HTTP/2 Support Check",
          "request": {
            "method": "GET",
            "url": "https://www.apple.com",
            "description": "Verify HTTP/2 multiplexing support — critical for SharePlay multiple streams"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Response received successfully', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Content encoding is efficient', function () {",
                  "    var encoding = pm.response.headers.get('Content-Encoding');",
                  "    if (encoding) {",
                  "        pm.expect(encoding).to.be.oneOf(['gzip', 'br', 'deflate']);",
                  "    }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "3.2 Concurrent Request Performance",
          "request": {
            "method": "GET",
            "url": "https://www.apple.com/shop",
            "description": "HTTP/2 multiplexing allows concurrent requests on one connection"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Response under 3 seconds', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});",
                  "",
                  "pm.test('Response body not empty', function () {",
                  "    pm.expect(pm.response.text()).to.not.be.empty;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "4. WebKit Network Process Validation",
      "description": "Tests simulating WebKit NetworkProcess behavior — URL loading, caching, redirects",
      "item": [
        {
          "name": "4.1 Redirect Chain Handling",
          "request": {
            "method": "GET",
            "url": "http://apple.com/iphone",
            "description": "WebKit NetworkProcess must handle redirect chains correctly"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Final response is successful', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has content', function () {",
                  "    pm.expect(pm.response.text().length).to.be.above(0);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "4.2 Cache Control Headers",
          "request": {
            "method": "GET",
            "url": "https://www.apple.com",
            "description": "Verify caching headers — affects reload behavior in Safari sharing"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Cache-Control header present', function () {",
                  "    pm.expect(pm.response.headers.has('Cache-Control') || pm.response.headers.has('ETag')).to.be.true;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "4.3 Content-Type Validation",
          "request": {
            "method": "GET",
            "url": "https://www.apple.com",
            "description": "Content-Type determines how shared links render in Messages/AirDrop preview"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Content-Type is text/html', function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('text/html');",
                  "});",
                  "",
                  "pm.test('Character encoding specified', function () {",
                  "    var ct = pm.response.headers.get('Content-Type');",
                  "    pm.expect(ct.toLowerCase()).to.include('utf-8');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "4.4 Error Response Handling (404)",
          "request": {
            "method": "GET",
            "url": "https://www.apple.com/this-page-does-not-exist-qe-test",
            "description": "WebKit must handle error responses gracefully — no crash on bad shared links"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Server returns 404 for missing page', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([404, 200]);",
                  "    // Apple may return 200 with custom error page",
                  "});",
                  "",
                  "pm.test('Response body present (custom error page)', function () {",
                  "    pm.expect(pm.response.text().length).to.be.above(0);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "4.5 Large Response Handling",
          "request": {
            "method": "GET",
            "url": "https://developer.apple.com/documentation/foundation/nsuseractivity",
            "description": "Large page load — tests NetworkProcess memory handling for documentation links shared via AirDrop"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Large page loads successfully', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response time under 10 seconds', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(10000);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "5. Performance Benchmarks",
      "description": "Response time and throughput benchmarks for Sharing feature dependencies",
      "item": [
        {
          "name": "5.1 Apple.com TTFB (Time to First Byte)",
          "request": {
            "method": "GET",
            "url": "https://www.apple.com"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TTFB under 1 second', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});",
                  "",
                  "// Store for trend tracking",
                  "pm.environment.set('apple_ttfb_ms', pm.response.responseTime);"
                ]
              }
            }
          ]
        },
        {
          "name": "5.2 iCloud TTFB",
          "request": {
            "method": "GET",
            "url": "https://www.icloud.com"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('iCloud TTFB under 2 seconds', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  "pm.environment.set('icloud_ttfb_ms', pm.response.responseTime);"
                ]
              }
            }
          ]
        },
        {
          "name": "5.3 Developer Docs TTFB",
          "request": {
            "method": "GET",
            "url": "https://developer.apple.com"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Developer docs TTFB under 3 seconds', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
